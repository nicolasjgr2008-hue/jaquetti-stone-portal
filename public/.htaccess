Options -MultiViews
RewriteEngine On
RewriteCond %{REQUEST_URI} !^/autoridade-visual/
RewriteCond %{REQUEST_URI} !^/e-commerce/
RewriteCond %{REQUEST_URI} !^/landing-page/
RewriteCond %{REQUEST_URI} !^/site-institucional/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.html [QSA,L]

# Force index.html to never be cached
<Files "index.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires 0
</Files>

# Cache assets (JS/CSS with hashes) for 1 year
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
